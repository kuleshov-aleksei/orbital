# LiveKit Configuration
# Copy this file to .env and customize for your setup

# LiveKit server URL (WebSocket)
# For local development:
LIVEKIT_URL=ws://localhost:7880

# For production (example):
# LIVEKIT_URL=wss://your-livekit-server.com

# API credentials for generating access tokens
# These must match the keys in livekit-dev.yaml or your LiveKit server config
LIVEKIT_API_KEY=dev_key
LIVEKIT_API_SECRET=this_is_a_development_secret_key_32chars

# In production, use strong secrets (32+ characters)
# Generate with: openssl rand -base64 32
