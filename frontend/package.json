{
  "name": "orbital-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "git diff --name-only HEAD | grep '^frontend/' | sed 's|^frontend/||' | grep -E '\\.(ts|vue|js|tsx|jsx)$' | xargs -r eslint --config eslint.config.js --fix",
    "lint:full": "eslint --config eslint.config.js src/ --fix",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "livekit-client": "^2.17.1",
    "eslint-config-prettier": "^10.1.8",
    "pinia": "^2.1.0",
    "vue": "^3.3.0",
    "vue-boring-avatars": "^1.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^20.0.0",
    "@types/webrtc": "^0.0.47",
    "@vitejs/plugin-vue": "^4.4.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^17.2.0",
    "jiti": "^2.6.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.54.0",
    "unplugin-icons": "^0.19.0",
    "vite": "^4.4.0",
    "vitest": "^0.34.0",
    "vue-tsc": "^1.8.0"
  }
}
