{
  "name": "orbital-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "generate:licenses": "node scripts/generate-licenses.js",
    "convert:soundsprite": "node scripts/convert-soundsprite.js",
    "lint": "git diff --name-only HEAD | grep '^frontend/' | sed 's|^frontend/||' | grep -E '\\.(ts|vue|js|tsx|jsx)$' | xargs -r eslint --config eslint.config.js --fix",
    "lint:full": "eslint --config eslint.config.js src/ --fix",
    "prettier": "npx prettier . --write src/",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vueuse/sound": "^2.1.3",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.8",
    "eslint-plugin-prettier": "^5.5.6",
    "howler": "^2.2.4",
    "livekit-client": "^2.19.1",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "pixi.js": "^8.19.0",
    "typescript-eslint": "^8.60.1",
    "vue": "^3.5.35",
    "vue-advanced-cropper": "^2.8.9",
    "vue-boring-avatars": "^1.4.0",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0",
    "vue-virtual-scroller": "^3.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.85",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/webrtc": "^0.0.47",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.15",
    "prettier": "3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
