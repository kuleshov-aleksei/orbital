# Backend Dockerfile
FROM golang:1.25-alpine AS builder

# Accept version as build argument
ARG VERSION=dev-unknown

WORKDIR /app
COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags "-X github.com/kuleshov-aleksei/orbital/internal/version.Version=${VERSION}" -o orbital ./cmd/server

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /root/

COPY --from=builder /app/orbital .

EXPOSE 8080
CMD ["./orbital"]