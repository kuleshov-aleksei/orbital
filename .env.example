# Orbital Environment Configuration
# Copy this file to .env and customize values for your setup
# This is the unified configuration file for all Orbital components

# =============================================================================
# === ORBITAL BACKEND =========================================================
# =============================================================================

# Server port (default: 8080)
PORT=8080

# Server mode: 'debug', 'release', or 'test'
# Use 'release' for production
GIN_MODE=debug

# CORS allowed origins (comma-separated)
# Use '*' for development, specific domains for production
CORS_ORIGINS=*

# External URL - where to redirect users after OAuth authentication
# This should be your frontend application URL
EXTERNAL_URL=http://localhost:8080

# Electron Redirect URL - deep link URL for Electron OAuth callback
# When OAuth completes in external browser, redirect to this URL to open Orbital
ELECTRON_REDIRECT_URL=orbital://auth/callback

# =============================================================================
# === LIVEKIT SERVER ==========================================================
# =============================================================================

# LiveKit server WebSocket URL
# For Docker Compose deployment (internal communication between services):
LIVEKIT_URL=ws://livekit:7880

# For local development (outside Docker):
# LIVEKIT_URL=ws://localhost:7880

# For production with HTTPS (via Traefik with path-based routing):
# LIVEKIT_URL=wss://your-domain.com/livekit

# LiveKit API credentials for generating access tokens
# These must match the keys configured in livekit/livekit.yaml or livekit/livekit-dev.yaml
# IMPORTANT: Change these to secure values in production!
LIVEKIT_API_KEY=dev_key
LIVEKIT_API_SECRET=this_is_a_development_secret_key_32chars

# In production, generate strong secrets with:
# openssl rand -base64 32

# LiveKit external IP (if server is behind NAT)
# Uncomment and set for production deployments
# LIVEKIT_EXTERNAL_IP=your.public.ip.address

# =============================================================================
# === ORBITAL ROOM SETTINGS ===================================================
# =============================================================================

# Minimum users per room
ROOM_MIN_USERS=2

# Maximum users per room
ROOM_MAX_USERS=10

# Default max users for new rooms
ROOM_DEFAULT_MAX_USERS=10

# =============================================================================
# === ORBITAL WEBSOCKET =======================================================
# =============================================================================

# Ping timeout - time without ping before disconnecting a user (default: 30s)
# This allows users to reconnect within this window without being removed from rooms
WS_PING_TIMEOUT=30s

# How often to check for ping timeouts (default: 10s)
WS_PING_CHECK_INTERVAL=10s

# =============================================================================
# === ORBITAL SECURITY ========================================================
# =============================================================================

# JWT Secret - CHANGE THIS TO A SECURE RANDOM STRING IN PRODUCTION!
# Used to sign and verify JWT tokens
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Enable test endpoints (set to '1' for E2E testing only!)
# WARNING: This exposes dangerous test-only endpoints
ORBITAL_E2E=0

# =============================================================================
# === OAUTH & AUTHENTICATION ==================================================
# =============================================================================

# Discord OAuth Configuration
# Create an application at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URL=http://localhost:3000/api/auth/discord/callback
DISCORD_ELECTRON_REDIRECT_URL=http://localhost:3000/api/auth/discord/electron/callback

# Google OAuth Configuration
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_ELECTRON_REDIRECT_URL=http://localhost:3000/api/auth/google/electron/callback

# =============================================================================
# === ORBITAL LOGGING =========================================================
# =============================================================================

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# =============================================================================
# === ORBITAL FEATURE FLAGS ===================================================
# =============================================================================

# Enable WebRTC debug dashboard
ENABLE_DEBUG_DASHBOARD=true

# Enable screen sharing
ENABLE_SCREEN_SHARE=true

# =============================================================================
# === ORBITAL PRODUCTION SETTINGS (uncomment for production) ==================
# =============================================================================

# TLS certificate path
# TLS_CERT_PATH=/path/to/cert.pem

# TLS private key path  
# TLS_KEY_PATH=/path/to/key.pem

# External IP (if server is behind NAT)
# EXTERNAL_IP=your.public.ip.address
