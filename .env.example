# Example environment configuration for Orbital
# Copy this file to .env and customize values for your setup

# ============================================
# TURN Server Configuration
# ============================================

# Shared secret for TURN REST API authentication
# IMPORTANT: Change this to a secure random string in production!
TURN_SECRET=pink-goose

# TURN server URL (plain TCP/UDP)
# For local development, use your machine's LAN IP instead of localhost
# Format: turn:<hostname_or_ip>:<port>
TURN_URL=turn:192.168.1.169:3478

# TURN server URL (TLS encrypted)
# Format: turns:<hostname_or_ip>:<port>
TURN_TLS_URL=turns:192.168.1.169:5349

# STUN server URLs (comma-separated list)
# These are public Google STUN servers, safe to use
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN realm for authentication
TURN_REALM=orbital

# TURN credential lifetime in seconds (default: 86400 = 24 hours)
TURN_CREDENTIAL_TTL=86400

# ============================================
# Server Configuration
# ============================================

# Server port (default: 8080)
PORT=8080

# Server mode: 'debug', 'release', or 'test'
# Use 'release' for production
GIN_MODE=debug

# CORS allowed origins (comma-separated)
# Use '*' for development, specific domains for production
CORS_ORIGINS=*

# ============================================
# Room Configuration
# ============================================

# Minimum users per room
ROOM_MIN_USERS=2

# Maximum users per room
ROOM_MAX_USERS=10

# Default max users for new rooms
ROOM_DEFAULT_MAX_USERS=10

# ============================================
# Security & Rate Limiting
# ============================================

# Enable test endpoints (set to '1' for E2E testing only!)
# WARNING: This exposes dangerous test-only endpoints
ORBITAL_E2E=0

# ============================================
# Logging
# ============================================

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# ============================================
# Feature Flags
# ============================================

# Enable WebRTC debug dashboard
ENABLE_DEBUG_DASHBOARD=true

# Enable screen sharing
ENABLE_SCREEN_SHARE=true

# ============================================
# Production Settings (uncomment for production)
# ============================================

# TLS certificate path
# TLS_CERT_PATH=/path/to/cert.pem

# TLS private key path  
# TLS_KEY_PATH=/path/to/key.pem

# External IP (if server is behind NAT)
# EXTERNAL_IP=your.public.ip.address
