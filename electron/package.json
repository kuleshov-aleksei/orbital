{
  "name": "orbital-desktop",
  "version": "1.0.0",
  "description": "The Orbital - Voice Chat Desktop App",
  "main": "dist-electron/main/index.js",
  "author": {
    "name": "Orbital Team",
    "email": "orbital@example.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/kuleshov-aleksei/orbital",
  "desktopName": "orbital",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://localhost:3001"
    }
  },
  "scripts": {
    "dev": "VITE_DEV_SERVER_URL=http://localhost:3001 npx vite",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').cpSync('../frontend/dist','dist',{recursive:true})\"",
    "prebuild:venmic": "npx tsx scripts/copyVenmic.mts",
    "build": "npx vite build && npx tsx scripts/copyVenmic.mts && electron-builder --linux",
    "build:win": "npx vite build && npx tsx scripts/copyVenmic.mts && electron-builder --win",
    "build:linux": "npx vite build && npx tsx scripts/copyVenmic.mts && electron-builder --linux",
    "build:all": "npx vite build && npx tsx scripts/copyVenmic.mts && electron-builder -wl",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@vencord/venmic": "^6.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "livekit-client": "^2.18.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-advanced-cropper": "^2.8.9",
    "vue-boring-avatars": "^1.4.0",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.80",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.10",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-node-polyfills": "^0.26.0"
  }
}
